---
interface Props {
  title: string;
  description: string;
  tags: string[];
  link?: string;
}

const { title, description, tags, link } = Astro.props;
---
<div class="bg-surface border border-white/10 p-6 rounded-2xl hover:border-primary/50 transition-all group">
  <div class="flex flex-wrap gap-2 mb-4">
    {tags.map(tag => (
      <span class="text-[10px] font-mono bg-primary/10 text-primary px-2 py-0.5 rounded-full border border-primary/20">
        {tag}
      </span>
    ))}
  </div>
  <h3 class="text-xl font-bold text-white mb-2 group-hover:text-primary transition-colors">{title}</h3>
  <p class="text-slate-400 text-sm leading-relaxed mb-4">
    {description}
  </p>
  {link && (
    <a href={link} class="text-primary text-sm font-medium hover:underline inline-flex items-center gap-1">
      Ver detalles →
    </a>
  )}
</div>