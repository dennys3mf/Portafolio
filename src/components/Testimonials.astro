---
/**
 * Componente Testimonials
 * Muestra testimonios destacados con carrusel
 */
import { getFeaturedTestimonials } from '../lib/db';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const testimonials = await getFeaturedTestimonials();

const StarSVG = () => (
  <svg class="w-[1.125rem] h-[1.125rem]" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
  </svg>
);
---

<section id="testimonios" class="max-w-6xl mx-auto px-6 py-20">
  <div class="flex flex-col gap-4 mb-12">
    <h2 class="text-4xl md:text-5xl font-bold tracking-tight">
      {lang === 'es' ? 'Testimonios' : 'Testimonials'}
    </h2>
    <p class="text-slate-400 text-lg max-w-2xl">
      {lang === 'es' 
        ? 'Qué dicen mis clientes y colegas sobre mi trabajo'
        : 'What my clients and colleagues say about my work'}
    </p>
  </div>

  {testimonials.length === 0 ? (
    <div class="text-center py-12">
      <p class="text-slate-400">{lang === 'es' ? 'No hay testimonios disponibles' : 'No testimonials available'}</p>
    </div>
  ) : (
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {testimonials.map((testimonial) => {
        const text = lang === 'es' ? testimonial.textEs : testimonial.textEn;

        return (
          <article class="p-6 rounded-2xl border border-white/10 bg-surface/50 backdrop-blur-sm hover:border-primary/50 transition-all">
            {/* Rating */}
            <div class="flex gap-1 mb-4">
              {[...Array(testimonial.rating)].map((_, i) => (
                <div class="text-amber-400">
                  <StarSVG />
                </div>
              ))}
              {[...Array(5 - testimonial.rating)].map((_, i) => (
                <div class="text-slate-600">
                  <StarSVG />
                </div>
              ))}
            </div>

            {/* Testimonial Text */}
            <blockquote class="text-slate-300 mb-6 italic">
              "{text}"
            </blockquote>

            {/* Cliente Info */}
            <div class="flex items-center gap-3 pt-4 border-t border-white/10">
              {testimonial.clientImage && (
                <img
                  src={testimonial.clientImage}
                  alt={testimonial.clientName}
                  class="w-12 h-12 rounded-full object-cover border border-white/10"
                />
              )}
              <div>
                <h4 class="font-semibold text-white">
                  {testimonial.clientName}
                </h4>
                <p class="text-sm text-slate-400">
                  {testimonial.clientRole}
                  {testimonial.clientCompany && (
                    <>
                      {' '}<span class="text-slate-600">@</span>{' '}
                      <span class="text-slate-300">{testimonial.clientCompany}</span>
                    </>
                  )}
                </p>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  )}
</section>
